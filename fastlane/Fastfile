# frozen_string_literal: true

default_platform(:ios)

def load_api_key_if_present
  app_store_connect_api_key(
    key_id: ENV['APP_STORE_CONNECT_API_KEY_KEY_ID'],
    issuer_id: ENV['APP_STORE_CONNECT_API_KEY_ISSUER_ID'],
    key_content: ENV['APP_STORE_CONNECT_API_KEY_KEY_CONTENT'].to_s.gsub('\\n', "\n"),
    is_key_content_base64: false,
    duration: 1200,
    in_house: false
  )
end

def sync_for_platform(platform_name:, readonly:)
  app_identifiers = [ENV['APP_IDENTIFIER'], ENV['WIDGET_IDENTIFIER']]
  api_key = load_api_key_if_present

  %w[development appstore].each do |cert_type|
    params = {
      type: cert_type,
      platform: platform_name,
      app_identifier: app_identifiers,
      readonly: readonly
    }
    params[:api_key] = api_key if api_key
    params[:force_for_new_devices] = true if !readonly && cert_type == 'development'

    sync_code_signing(**params)
  end
end

platform :ios do
  desc '同步 iOS 证书'
  lane :sync_certs do
    sync_for_platform(platform_name: 'ios', readonly: true)
  end

  desc '创建或更新 iOS 证书'
  lane :update_certs do
    sync_for_platform(platform_name: 'ios', readonly: false)
  end
end

platform :mac do
  desc '同步 macOS 证书'
  lane :sync_certs do
    sync_for_platform(platform_name: 'macos', readonly: true)
  end

  desc '创建或更新 macOS 证书'
  lane :update_certs do
    sync_for_platform(platform_name: 'macos', readonly: false)
  end
end
